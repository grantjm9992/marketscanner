# Polymarket bot configuration. Copy to .env and fill in.
# Defaults are safe for paper mode.

# --- Mode ---
# One of: paper | live | backtest
MODE=paper

# --- Polymarket ---
POLYMARKET_CLOB_HOST=https://clob.polymarket.com
POLYMARKET_WS_HOST=wss://ws-subscriptions-clob.polymarket.com/ws/market
POLYMARKET_CHAIN_ID=137
# Required for MODE=live. NEVER commit a real key. Use a dedicated bot wallet.
POLYMARKET_PRIVATE_KEY=

# --- Database ---
# Pick one of: sqlite | postgres
DATABASE_KIND=sqlite
# Used when DATABASE_KIND=sqlite
DATABASE_PATH=./data/bot.db
# Used when DATABASE_KIND=postgres (e.g. on Railway)
# DATABASE_URL=postgres://user:pass@host:5432/db
# Most managed Postgres providers require SSL with self-signed certs:
DATABASE_SSL=true

# --- Risk limits (USD) ---
RISK_MAX_POSITION_USD=100
RISK_MAX_TOTAL_DEPLOYED_USD=500
RISK_MAX_DAILY_LOSS_USD=50
RISK_MAX_ORDERS_PER_MINUTE=30
RISK_PER_MARKET_COOLDOWN_MS=60000
RISK_MAX_OPEN_ORDERS_PER_MARKET=4

# --- Simulator (paper / backtest) ---
SIMULATOR_LATENCY_MS=250
SIMULATOR_STARTING_CASH_USD=1000

# --- Strategy ---
# One of: wide-spread-market-maker | smart-money-follower | rewarded-market-maker | weather-forecast
STRATEGY_NAME=wide-spread-market-maker
# Comma-separated condition IDs.
STRATEGY_MARKETS=
# JSON object of strategy params. Example:
# STRATEGY_PARAMS={"minSpread":0.03,"quoteSize":10,"maxHoldMinutes":30}
STRATEGY_PARAMS={}

# --- SmartMoneyFollower (only used when STRATEGY_NAME=smart-money-follower) ---
# Comma-separated lowercased Polygon addresses to follow. Empty = strategy
# is a no-op.
#
# DO NOT just paste the leaderboard. Pick wallets you've verified have
# real edge (high realized PnL on closed positions, not unrealized; high
# hit rate; consistent over months). Otherwise you copy the rn1-style
# trap and bleed slowly.
SMART_MONEY_WALLETS=
SMART_MONEY_DATA_API_HOST=https://data-api.polymarket.com
# How often to poll per wallet, in ms.
SMART_MONEY_POLL_MS=5000
# Our copy size in USD per signal. Independent of what the source traded.
SMART_MONEY_COPY_USD=10
# Source trades smaller than this are ignored (noise filter, USD notional).
SMART_MONEY_MIN_SOURCE_USD=200
# Drop signals older than this. The whole point is being fast.
SMART_MONEY_MAX_AGE_MS=30000
# Skip if the book has moved more than this many cents from the source price.
SMART_MONEY_MAX_DRIFT_CENTS=0.03
# How to execute the copy: taker_market | taker_limit_at_touch
SMART_MONEY_EXECUTION_MODE=taker_limit_at_touch
# Don't re-copy the same wallet on the same market within this window.
SMART_MONEY_PER_MARKET_COOLDOWN_MS=300000

# --- WeatherForecastStrategy (only used when STRATEGY_NAME=weather-forecast) ---
# Free, no API key. See https://open-meteo.com/.
WEATHER_OPEN_METEO_HOST=https://api.open-meteo.com/v1/forecast
# Minimum edge between model probability and market price required to
# act. 0.05 = 5¢. Lower = more trades, more risk of model error.
WEATHER_MIN_EDGE=0.05
# Notional USD per trade. Fixed-fraction sizing (Phase 1 doesn't scale
# by edge or use Kelly).
WEATHER_ORDER_USD=20
# Hard cap on shares per single order, regardless of orderUsd.
WEATHER_MAX_ORDER_SIZE=200
# Don't take YES at extreme prices — at 0.99 a wrong call loses 99x
# the right one. Stay inside [MIN_YES_PRICE, MAX_YES_PRICE].
WEATHER_MAX_YES_PRICE=0.97
WEATHER_MIN_YES_PRICE=0.03
# Per-market cooldown after a trade.
WEATHER_PER_MARKET_COOLDOWN_MS=600000
# Restrict the strategy to one side of the trade, or allow both:
#   both       - take whichever side has edge (default)
#   sell_only  - swisstony pattern: only sell YES at near-cert prices
#   buy_only   - maskache2 pattern: only buy YES on long shots
WEATHER_TRADE_DIRECTION=both

# --- Recording ---
RECORD_SNAPSHOTS=true

# --- Logging ---
LOG_LEVEL=info

# --- Market discovery (Polymarket Gamma API) ---
# When enabled, the bot queries Gamma at startup and selects markets
# matching the filters below. Discovered markets are merged with any
# explicit STRATEGY_MARKETS, so you can use both together.
#
# This is the on/off switch (true|false):
MARKET_DISCOVERY_ENABLED=false
MARKET_DISCOVERY_GAMMA_HOST=https://gamma-api.polymarket.com
# CATEGORIES is a list, not a boolean. Comma-separated category names,
# or empty to match any category. Examples:
#   MARKET_DISCOVERY_CATEGORIES=Sports,Politics
#   MARKET_DISCOVERY_CATEGORIES=         (any)
MARKET_DISCOVERY_CATEGORIES=
# Real Polymarket markets typically have 24h volumes of $500-$50k and
# spreads of 1-3¢. Defaults below are tuned to that reality, not the
# unrealistic $50k+ / 3¢+ envelope you'd want in an ideal world.
MARKET_DISCOVERY_MIN_VOLUME_USD=5000
MARKET_DISCOVERY_MIN_DAYS_TO_RESOLUTION=7
MARKET_DISCOVERY_MIN_SPREAD=0.01
MARKET_DISCOVERY_MAX_SPREAD=0.10
MARKET_DISCOVERY_LIMIT=5
# Only return markets with a CLOB maker-rewards rate > 0. Pair with
# STRATEGY_NAME=rewarded-market-maker for structurally-positive-EV
# liquidity provision (Polymarket pays you a daily subsidy for posting
# tight quotes inside the rewards band).
MARKET_DISCOVERY_REQUIRE_REWARDS=false
# Optional case-insensitive regex applied to market questions. Empty
# means no filter. Useful to scope discovery to a topic the strategy
# understands. Examples:
#   weather:   temperature|weather|rain|snow|hottest|coldest
#   sports:    NBA|NFL|MLB|NHL|tennis|football|soccer|cricket
#   crypto:    bitcoin|ethereum|BTC|ETH|crypto
MARKET_DISCOVERY_QUESTION_REGEX=
