# Polymarket bot configuration. Copy to .env and fill in.
# Defaults are safe for paper mode.

# --- Mode ---
# One of: paper | live | backtest
MODE=paper

# --- Polymarket ---
POLYMARKET_CLOB_HOST=https://clob.polymarket.com
POLYMARKET_WS_HOST=wss://ws-subscriptions-clob.polymarket.com/ws/market
POLYMARKET_CHAIN_ID=137
# Required for MODE=live. NEVER commit a real key. Use a dedicated bot wallet.
POLYMARKET_PRIVATE_KEY=

# --- Database ---
# Pick one of: sqlite | postgres
DATABASE_KIND=sqlite
# Used when DATABASE_KIND=sqlite
DATABASE_PATH=./data/bot.db
# Used when DATABASE_KIND=postgres (e.g. on Railway)
# DATABASE_URL=postgres://user:pass@host:5432/db
# Most managed Postgres providers require SSL with self-signed certs:
DATABASE_SSL=true

# --- Risk limits (USD) ---
RISK_MAX_POSITION_USD=100
RISK_MAX_TOTAL_DEPLOYED_USD=500
RISK_MAX_DAILY_LOSS_USD=50
RISK_MAX_ORDERS_PER_MINUTE=30
RISK_PER_MARKET_COOLDOWN_MS=60000
RISK_MAX_OPEN_ORDERS_PER_MARKET=4

# --- Simulator (paper / backtest) ---
SIMULATOR_LATENCY_MS=250
SIMULATOR_STARTING_CASH_USD=1000

# --- Strategy ---
STRATEGY_NAME=wide-spread-market-maker
# Comma-separated condition IDs.
STRATEGY_MARKETS=
# JSON object of strategy params. Example:
# STRATEGY_PARAMS={"minSpread":0.03,"quoteSize":10,"maxHoldMinutes":30}
STRATEGY_PARAMS={}

# --- Recording ---
RECORD_SNAPSHOTS=true

# --- Logging ---
LOG_LEVEL=info

# --- Market discovery (Polymarket Gamma API) ---
# When enabled, the bot queries Gamma at startup and selects markets
# matching the filters below. Discovered markets are merged with any
# explicit STRATEGY_MARKETS, so you can use both together.
#
# This is the on/off switch (true|false):
MARKET_DISCOVERY_ENABLED=false
MARKET_DISCOVERY_GAMMA_HOST=https://gamma-api.polymarket.com
# CATEGORIES is a list, not a boolean. Comma-separated category names,
# or empty to match any category. Examples:
#   MARKET_DISCOVERY_CATEGORIES=Sports,Politics
#   MARKET_DISCOVERY_CATEGORIES=         (any)
MARKET_DISCOVERY_CATEGORIES=
# Real Polymarket markets typically have 24h volumes of $500-$50k and
# spreads of 1-3¢. Defaults below are tuned to that reality, not the
# unrealistic $50k+ / 3¢+ envelope you'd want in an ideal world.
MARKET_DISCOVERY_MIN_VOLUME_USD=5000
MARKET_DISCOVERY_MIN_DAYS_TO_RESOLUTION=7
MARKET_DISCOVERY_MIN_SPREAD=0.01
MARKET_DISCOVERY_MAX_SPREAD=0.10
MARKET_DISCOVERY_LIMIT=5
