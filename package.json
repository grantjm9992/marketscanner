{
  "name": "polymarket-bot",
  "version": "0.1.0",
  "description": "TypeScript prediction-market trading bot for Polymarket. Three modes (backtest, paper, live) behind one strategy interface.",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && pnpm run copy-assets",
    "copy-assets": "node -e \"import('node:fs/promises').then(async fs => { await fs.cp('src/persistence/migrations', 'dist/src/persistence/migrations', { recursive: true }); })\"",
    "start": "node --enable-source-maps dist/src/main.js",
    "dev": "tsx src/main.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@polymarket/clob-client": "^4.0.0",
    "better-sqlite3": "^11.0.0",
    "ethers": "^5.7.2",
    "pino": "^9.0.0",
    "pino-pretty": "^11.0.0",
    "ws": "^8.16.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.10",
    "@types/node": "^20.12.0",
    "@types/ws": "^8.5.10",
    "@typescript-eslint/eslint-plugin": "^7.7.0",
    "@typescript-eslint/parser": "^7.7.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.2.5",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^1.5.0"
  }
}
